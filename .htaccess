RewriteEngine On

# Set this to the sub-path where the module lives on the server.
# Example: if the URL is https://example.com/pohl/ use: RewriteBase /pohl/
# If it lives at the domain root use: RewriteBase /
RewriteBase /pohl/

# ── API routes → PHP files ────────────────────────────────────────────────────
RewriteRule ^api/users/check$       api/users/check.php   [L]
RewriteRule ^api/users/create$      api/users/create.php  [L]
RewriteRule ^api/progress/save$     api/progress/save.php [L]
RewriteRule ^api/progress/([^/]+)$  api/progress/load.php?username=$1 [L,QSA]

# ── Angular client-side routing ───────────────────────────────────────────────
# Serve real files and directories as-is; everything else → index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
